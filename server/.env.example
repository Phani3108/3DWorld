# Server
PORT=3000
MAX_JSON_BODY_BYTES=1048576
CLIENT_URL=http://localhost:5173
EXTRA_ALLOWED_ORIGIN=
SERVER_URL=http://localhost:3000

# Persistence (optional)
# DATABASE_URL=postgresql://user:password@localhost:5432/3dworld
# In production, strict DB SSL is enabled by default unless you set this to false.
# DB_SSL_REJECT_UNAUTHORIZED=true
# DB_SSL_REJECT_UNAUTHORIZED=false

# Feature toggles
# OPEN_ACCESS defaults to:
# - 1 in development
# - 0 in production
# Set explicitly only if you need to override that behavior.
# OPEN_ACCESS=1
# Trust X-Forwarded-* headers only behind a trusted reverse proxy (Render/Fly/Railway/etc).
# TRUST_PROXY=1
# DEV_MODE enables extra local-only diagnostics (for example additional health metadata).
DEV_MODE=0
